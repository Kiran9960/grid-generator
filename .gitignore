# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/dist

# misc
.DS_Store
**/.DS_Store
.vscode/
.idea/
.cache/
.turbo/
.swc/
*.pem
*.log
*.orig
*.bak
*.tmp

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# OS files
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/

# test / lint caches
.eslintcache
.stylelintcache
/playwright-report/
/test-results/
/coverage/

# package manager locks (keep only one)
# yarn.lock  ← uncomment to ignore if using npm
# package-lock.json  ← uncomment to ignore if using yarn

# local scripts / scratch files
scratch.*
tmp/
temp/
